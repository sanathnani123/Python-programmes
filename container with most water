class Solution(object):
    def maxArea(self, height):
        max_area = 0

        for i in range(len(height)):
            for j in range(i + 1, len(height)):
                width = j - i
                h = min(height[i], height[j])
                area = width * h

                if area > max_area:
                    max_area = area

        return max_area
